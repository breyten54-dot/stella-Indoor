rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authentication helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthEmail() {
      return isSignedIn() ? request.auth.token.email : null;
    }

    function isOwner(userEmail) {
      return isSignedIn() && getAuthEmail().lower() == userEmail.lower();
    }

    function isMember(booking) {
      return isSignedIn() && getAuthEmail().lower() in booking.members;
    }

    function isAdmin() {
      // Any signed-in user whose email exists as a document ID in the
      // /admins collection is considered an admin.
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(getAuthEmail().lower()));
    }

    // Validation helpers
    function isValidBooking(booking) {
      return booking.keys().hasAll(['courtId', 'courtName', 'date', 'startTime', 'endTime', 'status', 'clientDetails'])
        && booking.status in ['pending', 'confirmed', 'cancelled'];
    }

    function isValidUser(user) {
      return user.keys().hasAll(['email', 'name'])
        && user.email.matches('^[^@]+@[^@]+$');
    }

    // Admins collection: a user can read only their own admins document
    // to determine whether they are an admin. Writes are managed manually
    // in the Firebase Console.
    match /admins/{email} {
      allow read: if isSignedIn() && email.lower() == getAuthEmail().lower();
      allow create, update, delete: if false;
    }

    // Users: public creation and read (client booking app)
    match /users/{email} {
      allow create: if isSignedIn()
        && email.lower() == getAuthEmail().lower()
        && isValidUser(request.resource.data);
      allow read: if isOwner(email) || isAdmin();
      allow update: if (isOwner(email) && isValidUser(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    // Bookings: authenticated users can create; owners/members/admins can read; owners/admins can update.
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userEmail) || isMember(resource.data) || isAdmin());
      allow create: if isSignedIn()
        && isValidBooking(request.resource.data)
        && request.resource.data.userEmail == getAuthEmail();
      allow update: if isSignedIn()
        && isValidBooking(request.resource.data)
        && (isAdmin() || (isOwner(resource.data.userEmail) && resource.data.userEmail == request.resource.data.userEmail));
      allow delete: if isAdmin();
    }

    // Booking invites: anyone with the link can read the invite details; creation is done by the Cloud Function.
    match /bookingInvites/{token} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(resource.data.createdBy);
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Pending bookings for conflict prevention
    match /pendingBookings/{id} {
      allow read, write: if isSignedIn()
        && request.resource.data.keys().hasAll(['courtId', 'date', 'startTime', 'endTime']);
    }

    // Notifications: created ONLY server-side (Cloud Functions bypass rules)
    // or by admins. Clients may read their own, flip their own read/shown
    // flags, and delete their own — nothing more.
    match /notifications/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userEmail) || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isOwner(resource.data.userEmail)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'shown']));
      allow delete: if isAdmin() || isOwner(resource.data.userEmail);
    }

    // Scheduled email reminders: admins only
    match /scheduledEmails/{id} {
      allow read, write, delete: if isAdmin();
    }

    // Admin push subscriptions: admins only
    match /adminSubscriptions/{id} {
      allow create, update: if isAdmin() && request.resource.data.keys().hasAll(['endpoint', 'keys']);
      allow read, delete: if isAdmin();
    }

    // Client push subscriptions: users manage only their own subscription documents.
    // The document ID may be either the email or a hash; the owning email is stored in userEmail.
    match /clientSubscriptions/{id} {
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasAll(['endpoint', 'keys', 'userEmail'])
        && isOwner(request.resource.data.userEmail);
      allow read, delete: if isSignedIn() && isOwner(resource.data.userEmail);
    }

    // Release notification deduplication markers: written by the Cloud Function only.
    match /releaseNotifications/{id} {
      allow read, write: if isAdmin();
    }

    // Blocked slots: admins write; authenticated users read for availability checks
    match /blockedSlots/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Block payment notes: admin-only metadata attached to blocked slots.
    match /blockNotes/{blockId} {
      allow read, write: if isAdmin();
    }

    // Clips and clip of the week: public read; admins write
    match /clips/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /clipOfTheWeek/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // App settings: admins read/write
    match /appSettings/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Password reset codes: deprecated, no access
    match /passwordResetCodes/{id} {
      allow read, write, delete: if false;
    }
  }
}
